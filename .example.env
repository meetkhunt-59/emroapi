# Server Configuration
PORT=9000
HOST=0.0.0.0

# Security
API_KEY=your-secure-api-key-here
MAX_REQUESTS_PER_MINUTE=100

# CORS Settings (comma-separated list)
ALLOWED_ORIGINS= [http://localhost:3000, http://example.com]

# Storage Settings
MAX_FILE_SIZE_MB=20
STORAGE_PATH=/app/storage

# Logging
LOG_LEVEL=INFO